# ── LLM Provider API Keys ───────────────────────────────────────
# At least one provider is required. Gemini is recommended as the
# default for planner, researcher, distiller, formatter, and browser.

GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Optional providers (uncomment to enable)
# NVIDIA_API_KEY=your-nvidia-api-key
# CEREBRAS_API_KEY=your-cerebras-api-key
# OPEN_ROUTER_API_KEY=your-openrouter-api-key
# GITHUB_ACCESS_TOKEN=your-github-token

# ── Ollama (local models) ──────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ── Model overrides (optional) ─────────────────────────────────
# Override the default model for any provider:
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=openai/gpt-oss-120b
# NVIDIA_MODEL=deepseek-ai/deepseek-v3.2
# GITHUB_MODEL=openai/gpt-4.1-mini

# ── Embedding (optional) ───────────────────────────────────────
# Defaults to Ollama nomic-embed-text with Gemini fallback.
# EMBED_OLLAMA_MODEL=nomic-embed-text
# EMBED_FALLBACK_PROVIDER=gemini
# EMBED_FALLBACK_MODEL=gemini-embedding-001
# EMBED_ORDER=ollama,gemini

# ── Gateway settings (optional) ────────────────────────────────
# GATEWAY_V9_PORT=8109
# LLM_ORDER=gemini,groq,cerebras,openrouter,github,nvidia,ollama
# ROUTER_ORDER=cerebras,groq,github,nvidia
